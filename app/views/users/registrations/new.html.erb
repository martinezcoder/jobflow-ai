<h1 class="text-2xl font-semibold mb-6">Sign up</h1>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4 max-w-md" }) do |f| %>
  <%= render "users/shared/error_messages", resource: resource %>

  <div>
    <%= f.label :email, class: "block text-sm font-medium mb-1" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.label :password, class: "block text-sm font-medium mb-1" %>
    <% if @minimum_password_length %>
      <p class="text-sm text-gray-600 mb-1">(<%= @minimum_password_length %> characters minimum)</p>
    <% end %>
    <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.label :password_confirmation, class: "block text-sm font-medium mb-1" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.submit "Sign up", class: "rounded bg-black px-4 py-2 text-white font-medium cursor-pointer" %>
  </div>
<% end %>
