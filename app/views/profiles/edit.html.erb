<h1 class="text-2xl font-semibold mb-6">Edit profile</h1>

<%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-4 max-w-md" do |f| %>
  <% if @user.errors.any? %>
    <div id="error_explanation" data-turbo-temporary class="mb-4 rounded border border-red-300 bg-red-50 p-4 text-red-800">
      <h2 class="font-semibold mb-2">
        <%= pluralize(@user.errors.count, "error") %> prohibited this profile from being saved:
      </h2>
      <ul class="list-disc pl-5 space-y-1">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :first_name, class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name", class: "w-full rounded border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.label :last_name, class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :last_name, autocomplete: "family-name", class: "w-full rounded border border-gray-300 px-3 py-2" %>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit "Save changes", class: "rounded bg-black px-4 py-2 text-white font-medium cursor-pointer" %>
    <%= link_to "Cancel", profile_path, class: "underline" %>
  </div>
<% end %>
